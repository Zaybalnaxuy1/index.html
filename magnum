<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Выбор проема гаража</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #111;
            color: #fff;
            font-family: sans-serif;
            text-align: center;
            overflow: hidden;
        }
        #canvas-container {
            position: relative;
            display: inline-block;
            margin-top: 10px;
            max-width: 100vw;
            max-height: 80vh;
        }
        canvas {
            border: 1px solid #444;
            max-width: 100%;
            max-height: 80vh;
            display: block;
        }
        #info {
            padding: 10px;
            font-size: 14px;
            color: #aaa;
        }
    </style>
</head>
<body>

    <div id="info">Отметьте 4 угла проема ворот (ЛВ, ПВ, ПН, ЛН)</div>
    <div id="canvas-container">
        <canvas id="garageCanvas"></canvas>
    </div>

    <script>
        // Инициализируем Telegram Web App
        const tg = window.Telegram.WebApp;
        tg.expand(); // Разворачиваем на весь экран

        // Получаем URL картинки, который бот передаст в параметрах (например, index.html?img=...)
        const urlParams = new URLSearchParams(window.location.search);
        const imgUrl = urlParams.get('img');

        const canvas = document.getElementById('garageCanvas');
        const ctx = canvas.getContext('2d');
        const points = [];
        const img = new Image();

        img.onload = function() {
            // Устанавливаем реальный размер холста как у картинки
            canvas.width = img.width;
            canvas.height = img.height;
            ctx.drawImage(img, 0, 0);
        };
        // Разрешаем кросс-доменную загрузку, так как картинка будет лежать на серверах ТГ/твоем сервере
        img.crossOrigin = "anonymous"; 
        img.src = imgUrl || "https://via.placeholder.com/800x600.png?text=No+Image+Provided";

        canvas.addEventListener('click', function(e) {
            if (points.length >= 4) return;

            // Вычисляем координаты клика относительно реального (оригинального) размера картинки
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;

            const x = Math.round((e.clientX - rect.left) * scaleX);
            const y = Math.round((e.clientY - rect.top) * scaleY);

            points.push({x, y});

            // Рисуем точку и линию на экране для наглядности
            ctx.fillStyle = '#ff0000';
            ctx.beginPath();
            ctx.arc(x, y, Math.max(canvas.width * 0.01, 5), 0, 2 * Math.PI);
            ctx.fill();
            
            // Пишем номер точки
            ctx.fillStyle = '#ffffff';
            ctx.font = `${Math.max(canvas.width * 0.02, 14)}px Arial`;
            ctx.fillText(points.length, x + 10, y - 10);

            document.getElementById('info').innerText = `Отмечено точек: ${points.length} из 4`;

            // Если отметили все 4 точки, показываем главную кнопку Telegram
            if (points.length === 4) {
                tg.MainButton.text = "Подтвердить точки";
                tg.MainButton.show();
            }
        });

        // Отправка данных обратно в бота при клике на главную кнопку ТГ
        tg.onEvent('mainButtonClicked', function() {
            // Форматируем в строку, которую поймет наш coords_handler в Python
            const resultText = points.map(p => `${p.x},${p.y}`).join('\n');
            tg.sendData(resultText); // Отправляет данные боту и закрывает Web App
        });
    </script>
</body>
</html>
